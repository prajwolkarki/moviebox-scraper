# ─────────────────────────────────────────────
# MovieBox API Server – environment variables
# Copy to .env and fill in as needed.
# ─────────────────────────────────────────────

# HTTP port (default: 3000)
PORT=3000

# Bearer token for authenticated requests.
# Leave blank – the server obtains one automatically at runtime
# from the x-user response header.
MOVIEBOX_AUTH_TOKEN=

# Override the HMAC signing keys only if the upstream app changes them.
MOVIEBOX_SECRET_KEY_DEFAULT=76iRl07s0xSN9jqmEWAt79EBJZulIQIsV64FZr2O
MOVIEBOX_SECRET_KEY_ALT=Xqn2nnO41/L92o1iuXhSLHTbXvY4Z5ZZ62m8mSLA

# ─────────────────────────────────────────────
# Homepage tab IDs
#
# The Android app organises content into integer-indexed tabs.
# tabId=0 is confirmed (main/home tab). The others are educated guesses.
# If a category returns wrong content, increment TAB_MOVIE / TAB_TV / etc.
# by 1 until it looks right, or monitor the app's traffic with a proxy.
# ─────────────────────────────────────────────
TAB_HOME=0
TAB_MOVIE=1
TAB_TV=2
TAB_ANIMATION=3
TAB_RANKING=4
